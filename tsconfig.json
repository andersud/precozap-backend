{
  "compilerOptions": {
    "target": "ES2022",

    // 🔥 compatível com Node moderno (Render)
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "lib": ["ES2022"],

    "outDir": "dist",
    "rootDir": "src",

    "strict": true,

    // compatibilidade
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,

    // evita erro de types no Node
    "types": ["node"],

    "typeRoots": ["./node_modules/@types", "./src/@types"]
  },

  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}