{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022", "DOM"],

    "outDir": "dist",
    "rootDir": "src",

    "baseUrl": ".",

    "paths": {
      "@modules/*": ["src/modules/*"],
      "@shared/*": ["src/shared/*"],
      "@infra/*": ["src/infra/*"]
    },

    "ignoreDeprecations": "5.0",

    "types": ["node"],

    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}