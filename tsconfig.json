{ "compilerOptions": {
   "target": "ES2022",
   "module": "commonjs", 
   "lib": ["ES2022"], 
   
   "outDir": "dist", 
   "rootDir": "src",

   "baseUrl": ".", 
   "paths": { 
    "@modules/*": ["src/modules/*"], 
    "@shared/*": ["src/shared/*"],
    "@infra/*": ["src/infra/*"] 
  },
  
   "strict": true, 
   "esModuleInterop": true, 
   "skipLibCheck": true, 
   "forceConsistentCasingInFileNames": true, 
   "resolveJsonModule": true, 

   "declaration": true, 
   "declarationMap": true, 
   "sourceMap": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}