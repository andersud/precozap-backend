{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],

    "outDir": "dist",
    "rootDir": "src",

    // ✅ NECESSÁRIO para aliases
    "baseUrl": ".",

    "paths": {
      "@modules/*": ["src/modules/*"],
      "@shared/*": ["src/shared/*"],
      "@infra/*": ["src/infra/*"]
    },

    // ✅ Corrige aviso do TypeScript (versão compatível)
    "ignoreDeprecations": "5.0",

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,

    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}