generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id           String   @id @default(uuid())
  name         String
  category     String
  description  String?
  image        String?

  rating       Float    @default(0)
  reviews      Int      @default(0)
  bestPrice    Float    @default(0)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // 🔥 RELAÇÕES
  prices       MarketplacePrice[]
  priceHistory PriceHistory[]

  // 🔥 INDEXES (performance)
  @@index([category])
  @@index([bestPrice])
  @@index([createdAt])
}

model MarketplacePrice {
  id            String   @id @default(uuid())
  productId     String
  marketplace   String
  price         Float

  originalPrice Float?
  discount      Float?
  shipping      String?
  inStock       Boolean   @default(true)
  installments  String?
  url           String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // 🔥 RELAÇÃO
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  // 🔥 INDEXES OTIMIZADOS
  @@index([productId])
  @@index([marketplace])
  @@index([price])
  @@index([productId, marketplace])
}

model PriceHistory {
  id          String   @id @default(uuid())
  productId   String
  price       Float
  date        DateTime @default(now())

  marketplace String

  createdAt   DateTime @default(now())

  // 🔥 RELAÇÃO
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  // 🔥 INDEXES
  @@index([productId])
  @@index([date])
  @@index([marketplace])
  @@index([productId, date])
}