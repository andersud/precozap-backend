{
  "name": "precozap-backend",
  "version": "1.0.0",
  "description": "PreçoZap Backend API",
  "main": "dist/infra/http/server.js",
  "_moduleAliases": {
    "@modules": "dist/modules",
    "@shared": "dist/shared",
    "@infra": "dist/infra"
  },
  "scripts": {
    "dev": "tsx watch -r module-alias/register src/infra/http/server.ts",
    "build": "prisma generate && tsc",
    "start": "node -r module-alias/register dist/infra/http/server.js",
    "start:prod": "node -r module-alias/register dist/infra/http/server.js",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "express-validator": "^7.1.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "module-alias": "^2.3.4",
    "morgan": "^1.10.0",
    "node-cache": "^5.1.2",
    "node-fetch": "^3.3.2",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^20.19.39",
    "@types/uuid": "^10.0.0",
    "prisma": "^5.22.0",
    "tsx": "^4.16.2",
    "typescript": "^5.6.3"
  }
}
